# Database (SQLite via libSQL)
DATABASE_URL="file:./dev.db"

# ─── Live travel-data APIs (server-side only) ───────────────────────────────
# Itineraries are built from real provider data, not AI. Each provider degrades
# gracefully when its keys are absent.

# Flights & Hotels — Duffel (app.duffel.com → Developers → Access tokens).
# Powers flight search/booking AND hotel (Duffel Stays) search/booking, all
# inside Atlas. duffel_test_… tokens exercise the full flow without issuing real
# tickets or reservations; swap for duffel_live_… to sell for real. A live token
# also puts Duffel first in the trip-plan flight chain (force that with a test
# token via DUFFEL_IN_PLANS="true").
DUFFEL_ACCESS_TOKEN=""

# Flights — Amadeus (developers.amadeus.com → "Get Started Free"). Fallback
# fare source for the trip planner when Duffel has no live plan-mode results.
AMADEUS_API_KEY=""
AMADEUS_API_SECRET=""

# Airport transfer — Uber (developer.uber.com → "Get Access")
UBER_SERVER_TOKEN=""

# Airport data — AviationStack (aviationstack.com → "Get Free API Key")
AVIATIONSTACK_API_KEY=""

# Opt-in web scraping fallback (off by default — slow and usually blocked).
ENABLE_SCRAPING="false"

# Transactional email (optional — falls back to console logging if unset)
RESEND_API_KEY=""

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth (optional) — paste credentials from Google Cloud Console to
# enable the "Continue with Google" button. Leave blank to hide it.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"
