# Database (SQLite via libSQL)
DATABASE_URL="file:./dev.db"

# ─── Live travel-data APIs (server-side only) ───────────────────────────────
# Itineraries are built from real provider data, not AI. Each provider degrades
# gracefully when its keys are absent.

# Flights — Amadeus (developers.amadeus.com → "Get Started Free")
AMADEUS_API_KEY=""
AMADEUS_API_SECRET=""

# Hotels — Booking.com affiliate (booking.com/affiliate-program)
BOOKING_AFFILIATE_ID=""
BOOKING_API_TOKEN=""

# Airport transfer — Uber (developer.uber.com → "Get Access")
UBER_SERVER_TOKEN=""

# Airport data — AviationStack (aviationstack.com → "Get Free API Key")
AVIATIONSTACK_API_KEY=""

# Real flights + hotels via RapidAPI (booking-com15) — one key, no approval gate.
# rapidapi.com → search "Booking.com" (booking-com15) → Subscribe → copy the key.
RAPIDAPI_KEY=""

# Opt-in web scraping fallback (off by default — slow and usually blocked).
ENABLE_SCRAPING="false"

# Transactional email (optional — falls back to console logging if unset)
RESEND_API_KEY=""

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth (optional) — paste credentials from Google Cloud Console to
# enable the "Continue with Google" button. Leave blank to hide it.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"
