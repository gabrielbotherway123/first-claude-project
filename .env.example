# Database (SQLite via libSQL)
DATABASE_URL="file:./dev.db"

# Itinerary generation — required for the trip planner to produce options
ANTHROPIC_API_KEY=""

# Transactional email (optional — falls back to console logging if unset)
RESEND_API_KEY=""

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth (optional) — paste credentials from Google Cloud Console to
# enable the "Continue with Google" button. Leave blank to hide it.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"
