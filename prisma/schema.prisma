generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Auth (NextAuth / Auth.js) ───────────────────────────────

model User {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null for OAuth-only accounts

  // Saved profile & travel preferences
  phone                     String?
  defaultAirports           String? // JSON array of airport objects
  preferredAirlines         String? // JSON array of { airline, rewardsNumber }
  defaultCabinClass         String? // economy | business | first
  defaultHotelStars         Int?
  defaultLocationPreference String? // city_centre | airport | flexible
  standingRequirements      String?

  accounts     Account[]
  sessions     Session[]
  trips        Trip[]
  flightOrders FlightOrder[]
  hotelOrders  HotelOrder[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Travel planning ─────────────────────────────────────────

model Trip {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Traveller details
  fullName String
  email    String
  phone    String

  // Route & dates
  originCity     String
  destinations   String // JSON array of strings
  departureDate  String
  returnDate     String
  numberOfNights Int

  // Budget — separate, both optional
  totalBudget  Float? // legacy / combined (nullable)
  flightBudget Float?
  hotelBudget  Float?
  currency     String

  // Travellers & class
  numberOfTravellers Int
  cabinClass         String // economy | business | first

  // Airline preference
  preferredAirline String? // selected airline for this trip
  airlineRewards   String? // rewards number applied for this trip
  airlineNote      String? // set when the preferred airline isn't available on the route

  // Accommodation
  hotelStarRating    Int
  locationPreference String // city_centre | airport | flexible
  amenities          String // JSON array

  // Trip context
  tripPurpose         String
  specialRequirements String?
  loyaltyNumbers      String?

  plans   Plan[]
  booking Booking?

  @@index([userId])
}

model Plan {
  id            String @id @default(cuid())
  tripId        String
  trip          Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  planIndex     Int // 0-4
  label         String
  justification String

  flights  String // JSON
  hotel    String // JSON
  transfer String? // JSON ground-transport estimate

  flightCost   Float
  hotelCost    Float
  transferCost Float @default(0)
  totalCost    Float

  pricesFetchedAt String? // ISO timestamp of live price fetch
  sources         String? // JSON array of data providers
  dataNotes       String? // JSON array of components that could not be loaded live

  booking Booking?
}

model Booking {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  tripId    String    @unique
  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  planId    String    @unique
  plan      Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  status    String    @default("confirmed")
  reference String    @unique
  invoices  Invoice[]
}

// A real airline order placed through Duffel from the standalone
// Flights flow — independent of the Trip/Plan/Booking pipeline.
model FlightOrder {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  duffelOrderId    String  @unique
  bookingReference String // airline PNR from Duffel
  status           String  @default("confirmed")
  liveMode         Boolean @default(false) // false = test-mode order, no real ticket

  totalAmount Float
  currency    String

  originCity      String
  destinationCity String
  departureDate   String
  returnDate      String?
  cabinClass      String

  airlineName String
  airlineCode String
  passengers  String // JSON [{ title, givenName, familyName }]
  flights     String // JSON FlightDetail[]

  @@index([userId])
}

// A real accommodation booking placed through Duffel Stays.
model HotelOrder {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  duffelBookingId  String  @unique
  bookingReference String // accommodation's own confirmation reference
  status           String  @default("confirmed")
  liveMode         Boolean @default(false) // false = test-mode booking, no real reservation

  totalAmount Float
  currency    String

  accommodationName String
  city              String
  address           String?
  checkInDate       String
  checkOutDate      String
  roomName          String?

  guests String // JSON [{ givenName, familyName }]

  @@index([userId])
}

model Invoice {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  number    String // human invoice number, e.g. ATL-XXXX-01
  issueDate String // ISO date
  dueDate   String // ISO date

  recipientCompany String
  recipientAddress String

  travellerName  String
  travellerEmail String
  travellerPhone String?

  currency  String
  total     Float
  lineItems String // JSON: [{ description, amount }]

  @@index([bookingId])
  @@index([userId])
}
